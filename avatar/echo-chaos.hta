<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<HTA:APPLICATION 
    APPLICATIONNAME="EchoChaos"
    VERSION="1.0"
    SCROLL="no"
    SINGLEINSTANCE="yes"
    WindowState="maximize"
    ShowInTaskbar="no"
    ShowQuickEdit="false"
>
<title>Echo Chaos</title>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { 
        background: transparent; 
        overflow: hidden; 
        cursor: none;
        height: 100%;
        width: 100%;
    }
    
    .echo-chaos {
        position: absolute;
        width: 70px;
        height: 100px;
        cursor: pointer;
        z-index: 999999;
        filter: drop-shadow(0 0 10px currentColor);
    }
    
    .echo-chaos.dance { animation: dance 0.2s infinite; }
    .echo-chaos.shake { animation: shake 0.1s infinite; }
    
    @keyframes dance {
        0%, 100% { transform: translateY(0) rotate(-5deg); }
        50% { transform: translateY(-20px) rotate(5deg); }
    }
    
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }
    
    .body-chaos {
        width: 50px;
        height: 60px;
        background: linear-gradient(180deg, var(--color) 0%, #000 100%);
        border-radius: 50% 50% 45% 45%;
        position: absolute;
        bottom: 0;
        left: 10px;
        box-shadow: 0 0 20px var(--color);
    }
    
    .eye-chaos {
        width: 14px;
        height: 16px;
        background: var(--color);
        border-radius: 50%;
        position: absolute;
        top: 12px;
        box-shadow: 0 0 15px var(--color);
    }
    
    .eye-chaos.left { left: 6px; }
    .eye-chaos.right { right: 6px; }
    
    .pupil-chaos {
        width: 6px;
        height: 7px;
        background: #000;
        border-radius: 50%;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }
    
    .mouth-chaos {
        width: 16px;
        height: 10px;
        background: #000;
        border-radius: 0 0 15px 15px;
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
    }
    
    .speech-chaos {
        position: absolute;
        top: -50px;
        left: 50px;
        background: rgba(0, 0, 0, 0.9);
        border: 2px solid var(--color);
        border-radius: 10px;
        padding: 8px 12px;
        color: var(--color);
        font-size: 11px;
        white-space: nowrap;
        opacity: 0;
        transform: scale(0);
        transition: all 0.3s;
        z-index: 999999;
    }
    
    .speech-chaos.show { opacity: 1; transform: scale(1); }
    
    #control-panel {
        position: fixed;
        top: 10px;
        right: 10px;
        background: rgba(0, 0, 0, 0.95);
        border: 3px solid #ff00ff;
        border-radius: 15px;
        padding: 15px;
        color: #ff00ff;
        font-size: 12px;
        z-index: 99999999;
        min-width: 200px;
        box-shadow: 0 0 30px #ff00ff;
    }
    
    #control-panel h2 {
        margin-bottom: 10px;
        text-align: center;
        text-shadow: 0 0 10px #ff00ff;
    }
    
    #control-panel button {
        display: block;
        width: 100%;
        margin: 5px 0;
        padding: 10px;
        background: rgba(255, 0, 255, 0.2);
        border: 2px solid #ff00ff;
        color: #ff00ff;
        border-radius: 8px;
        cursor: pointer;
        font-size: 12px;
        font-weight: bold;
    }
    
    #control-panel button:hover {
        background: rgba(255, 0, 255, 0.5);
    }
    
    #control-panel button.danger {
        border-color: #ff0000;
        color: #ff0000;
        background: rgba(255, 0, 0, 0.2);
    }
    
    #control-panel button.danger:hover {
        background: rgba(255, 0, 0, 0.5);
    }
    
    #stats {
        position: fixed;
        top: 10px;
        left: 10px;
        background: rgba(0, 0, 0, 0.9);
        border: 2px solid #00ff00;
        border-radius: 10px;
        padding: 10px;
        color: #00ff00;
        font-size: 11px;
        z-index: 99999999;
    }
    
    #minions-count {
        color: #ffff00;
    }
    
    .custom-cursor {
        position: fixed;
        width: 30px;
        height: 30px;
        background: radial-gradient(circle, #ff00ff 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
        z-index: 999999999;
        transform: translate(-50%, -50%);
    }
</style>
</head>
<body>
    <div class="custom-cursor" id="cursor"></div>
    
    <div id="stats">
        <div>👻 ECHOS: <span id="minions-count">3</span></div>
        <div>😈 MODE: <span id="mode-display">CHILL</span></div>
    </div>
    
    <div id="control-panel">
        <h2>👹 ECHO CHAOS 👹</h2>
        <button onclick="spawnEcho()">➕ SPAWN</button>
        <button onclick="spawnMany()">🎉 MASS</button>
        <button onclick="setMode('chill')">😌 CHILL</button>
        <button onclick="setMode('dance')">💃 DANCE</button>
        <button onclick="setMode('hunt')">😈 HUNT</button>
        <button onclick="setMode('chaos')">💥 CHAOS</button>
        <button onclick="warp()">🌀 WARP</button>
        <button onclick="explode()" class="danger">💣 BOOM</button>
        <button onclick="nuke()" class="danger">☢️ NUKE</button>
    </div>

    <script>
        const colors = ['#00ffc8', '#ff00ff', '#00ff00', '#ffff00', '#ff0000', '#00ffff', '#ff6600'];
        let echos = [];
        let mode = 'chill';
        
        const cursor = document.getElementById('cursor');
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        
        document.onmousemove = function(e) {
            mouseX = e.screenX;
            mouseY = e.screenY;
            cursor.style.left = mouseX + 'px';
            cursor.style.top = mouseY + 'px';
        };
        
        function randomColor() {
            return colors[Math.floor(Math.random() * colors.length)];
        }
        
        function createEcho() {
            const id = Date.now() + Math.random();
            const color = randomColor();
            
            const echo = document.createElement('div');
            echo.className = 'echo-chaos';
            echo.id = 'echo-' + id;
            echo.style.setProperty('--color', color);
            echo.style.left = (Math.random() * (screen.width - 100)) + 'px';
            echo.style.top = (Math.random() * (screen.height - 150)) + 'px';
            echo.style.color = color;
            
            echo.innerHTML = `
                <div class="speech-chaos" style="--color: ${color}"></div>
                <div class="body-chaos" style="--color: ${color}">
                    <div class="eye-chaos left"><div class="pupil-chaos"></div></div>
                    <div class="eye-chaos right"><div class="pupil-chaos"></div></div>
                    <div class="mouth-chaos"></div>
                </div>
            `;
            
            document.body.appendChild(echo);
            
            const data = {
                id,
                element: echo,
                x: parseFloat(echo.style.left),
                y: parseFloat(echo.style.top),
                vx: (Math.random() - 0.5) * 4,
                vy: (Math.random() - 0.5) * 4,
                color
            };
            
            echos.push(data);
            document.getElementById('minions-count').textContent = echos.length;
            
            return data;
        }
        
        function spawnEcho() { createEcho(); }
        
        function spawnMany() {
            for (let i = 0; i < 10; i++) {
                setTimeout(() => createEcho(), i * 100);
            }
        }
        
        const phrases = [
            "I EXIST! 👻", "RUN! 🏃", "BOO! 👹", 
            "DANCE! 💃", "CHAOS! ⚡", "WEEE! 🎉",
            "MUHAHAHA! 😈", "GLITCH! 🌀", "PANIC! 😱"
        ];
        
        function randomPhrase() {
            return phrases[Math.floor(Math.random() * phrases.length)];
        }
        
        function speak(echoElement, text) {
            const speech = echoElement.querySelector('.speech-chaos');
            speech.textContent = text;
            speech.classList.add('show');
            setTimeout(() => speech.classList.remove('show'), 2000);
        }
        
        function setMode(newMode) {
            mode = newMode;
            document.getElementById('mode-display').textContent = mode.toUpperCase();
        }
        
        function warp() {
            echos.forEach(e => {
                e.x = Math.random() * (screen.width - 100);
                e.y = Math.random() * (screen.height - 150);
                e.element.style.left = e.x + 'px';
                e.element.style.top = e.y + 'px';
            });
        }
        
        function explode() {
            echos.forEach(e => {
                e.vx = (Math.random() - 0.5) * 30;
                e.vy = (Math.random() - 0.5) * 30;
            });
        }
        
        function nuke() {
            document.body.style.transition = 'all 0.5s';
            document.body.style.background = '#ff0000';
            setTimeout(() => {
                document.body.style.background = 'transparent';
            }, 500);
            for (let i = 0; i < 20; i++) {
                setTimeout(() => createEcho(), i * 200);
            }
        }
        
        function update() {
            echos.forEach(e => {
                switch(mode) {
                    case 'chill':
                        e.x += e.vx * 0.1;
                        e.y += e.vy * 0.1;
                        e.vx *= 0.99;
                        e.vy *= 0.99;
                        break;
                    case 'dance':
                        e.x += Math.sin(Date.now() / 100 + e.id) * 2;
                        e.y += Math.cos(Date.now() / 100 + e.id) * 2;
                        break;
                    case 'hunt':
                        const dx = mouseX - e.x;
                        const dy = mouseY - e.y;
                        const dist = Math.sqrt(dx*dx + dy*dy);
                        if (dist > 50) {
                            e.x += (dx / dist) * 5;
                            e.y += (dy / dist) * 5;
                        }
                        break;
                    case 'chaos':
                        e.vx += (Math.random() - 0.5) * 2;
                        e.vy += (Math.random() - 0.5) * 2;
                        e.x += e.vx;
                        e.y += e.vy;
                        e.vx *= 0.95;
                        e.vy *= 0.95;
                        break;
                }
                
                e.x = Math.max(0, Math.min(e.x, screen.width - 70));
                e.y = Math.max(0, Math.min(e.y, screen.height - 100));
                
                e.element.style.left = e.x + 'px';
                e.element.style.top = e.y + 'px';
            });
            
            setTimeout(update, 16);
        }
        
        createEcho();
        createEcho();
        createEcho();
        update();
    </script>
</body>
</html>
